# Local PostgreSQL (docker compose up -d)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=itofficerhub
DB_USER=postgres
DB_PASSWORD=postgres

# Or paste Neon connection as DATABASE_URL (postgres://user:pass@host/db?sslmode=require)
# DATABASE_URL=

# Or full JDBC URL
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/itofficerhub

JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
CORS_ORIGINS=http://localhost:5173

ADMIN_EMAIL=admin@itofficerhub.com
ADMIN_PASSWORD=Admin@123

PORT=8080
